# =============================================================================
# DPDP Consent Manager — Environment Variables (EXAMPLE / SAFE TO COMMIT)
# Copy this file to .env and fill in real values.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=dpdp

# Full DSN (used by services directly)
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/dpdp?sslmode=disable

# ─── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=9006

# RSA key paths for JWT RS256 signing (run `make gen-keys` to generate)
# Private key: used by auth-service to sign JWTs — NEVER share or commit
# Public key:  used by all other services to verify JWTs
JWT_PRIVATE_KEY_PATH=./services/auth-service/keys/auth_private.pem
JWT_EXPIRY_HOURS=24
