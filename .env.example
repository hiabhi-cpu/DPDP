# =============================================================================
# DPDP Consent Manager — Environment Variables (EXAMPLE / SAFE TO COMMIT)
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=dpdp

# Full DSN (used by services directly)
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/dpdp?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=9006

# RSA key paths for JWT RS256 signing (run `make gen-keys` to generate)
# Private key: used by auth-service to sign JWTs — NEVER share or commit
# Public key:  used by all other services to verify JWTs
JWT_PRIVATE_KEY_PATH=./services/auth-service/keys/auth_private.pem
JWT_PUBLIC_KEY_PATH=./services/auth-service/keys/auth_public.pem
JWT_EXPIRY_HOURS=24

# ─── Consent Service ──────────────────────────────────────────────────────────
CONSENT_SERVICE_PORT=9000

# ─── Audit Service ────────────────────────────────────────────────────────────
AUDIT_SERVICE_PORT=9001
AUDIT_SERVICE_URL=http://localhost:9001

# ─── Notification Service ─────────────────────────────────────────────────────
NOTIFICATION_SERVICE_PORT=9004

# MSG91 credentials — get from console.msg91.com
# Set to "mock" for local dev (OTP printed to stdout instead of real SMS)
MSG91_AUTH_KEY=mock
MSG91_SENDER_ID=DPDPCM
MSG91_TEMPLATE_ID=your_template_id_here

# ─── Cryptography / Secrets ───────────────────────────────────────────────────
# SYSTEM_SALT: global salt for HMAC_SHA256(mobile + SYSTEM_SALT + hospital_key)
# In production: fetched from AWS Secrets Manager — never stored here.
# For local dev: set a random string. Must NEVER change after first consent is captured.
SYSTEM_SALT=LOCAL-SYSTEM-SALT-FOR-DEV-ONLY-NEVER-USE-IN-PROD

# AWS Secrets Manager mock — set to true for local dev (reads from secrets/local_hospital_keys.json)
# Set to false in production (uses real AWS Secrets Manager in ap-south-1)
AWS_SECRETS_MOCK=true

# Path to local mock hospital keys (only used when AWS_SECRETS_MOCK=true)
LOCAL_SECRETS_PATH=./secrets/local_hospital_keys.json

# ─── AWS (production only — leave blank for local dev) ────────────────────────
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
