bin

# ─── Secrets — NEVER commit real credentials ───
.env

# ─── RSA Private Keys — NEVER commit ───
# Private key signs JWTs in auth-service. Public key (auth_public.pem) IS safe to commit.
**/keys/auth_private.pem

# ─── Generated by SQLC (regenerated by `make sqlc`) ───
services/*/db/sqlc/

# ─── Go build artifacts ───
*.exe
*.test
*.out
vendor/

# ─── IDE / OS noise ───
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ─── Docker volumes (if accidentally created locally) ───
postgres_data/
